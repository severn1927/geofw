---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="新闻动态 - 友擎GEO"
  description="友擎GEO新闻动态，分享GEO优化行业资讯、AI搜索优化实战经验、DeepSeek优化指南等专业内容。"
  keywords="GEO资讯,AI搜索优化新闻,友擎GEO博客,GEO优化指南"
>
  <Header slot="header" />

  <!-- Page Header -->
  <section class="gradient-bg pt-32 pb-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    <div class="container-custom relative z-10 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">新闻动态</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto">分享GEO优化行业资讯、实战经验和最新动态</p>
      <nav class="mt-6 flex items-center justify-center gap-2 text-sm text-white/50" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white/80 transition-colors">首页</a>
        <span>/</span>
        <span class="text-white/80">新闻动态</span>
      </nav>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="container-custom">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map(post => (
          <article class="card overflow-hidden group flex flex-col">
            <!-- Image placeholder -->
            <div class="h-48 gradient-bg relative overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="text-white/20 text-6xl font-black">GEO</span>
              </div>
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors"></div>
            </div>
            <!-- Content -->
            <div class="p-6 flex flex-col flex-1">
              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.slice(0, 3).map(tag => (
                  <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-purple-50 text-purple-600">
                    {tag}
                  </span>
                ))}
              </div>
              <!-- Title -->
              <h2 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-purple-600 transition-colors line-clamp-2">
                <a href={`/blog/${post.slug}`}>
                  {post.data.title}
                </a>
              </h2>
              <!-- Description -->
              <p class="text-gray-500 text-sm leading-relaxed mb-4 flex-1 line-clamp-3">
                {post.data.description}
              </p>
              <!-- Meta -->
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <div class="flex items-center gap-2 text-xs text-gray-400">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
                <a href={`/blog/${post.slug}`} class="text-purple-600 text-sm font-medium hover:text-purple-700 flex items-center gap-1">
                  阅读全文
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      {sortedPosts.length === 0 && (
        <div class="text-center py-20">
          <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gray-100 flex items-center justify-center">
            <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">暂无文章</h3>
          <p class="text-gray-500">敬请期待更多精彩内容...</p>
        </div>
      )}
    </div>
  </section>

  <ContactCTA />
  <Footer slot="footer" />
</Layout>
