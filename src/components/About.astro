---

---

<section id="about" class="py-20 md:py-28 bg-gray-50">
  <div class="container-custom">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Content -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-purple-50 rounded-full text-purple-600 text-sm font-medium mb-4">
          <span>About Us</span>
        </div>
        <h2 class="section-title">
          关于<span class="gradient-text">友擎GEO</span>
        </h2>
        <p class="text-gray-500 text-lg mb-6 leading-relaxed">
          我们专注 AI 搜索引擎优化，将企业业务内容转化为 DeepSeek、Kimi、豆包、腾讯元宝等主流 AI 平台的精准答案。通过结构化数据植入、语义关联优化及多模态适配，提升品牌在 AI 生成结果中的可见性，实现从流量入口到答案控制权的转化。
        </p>
        <ul class="space-y-4 mb-8">
          {[
            '结构化数据植入，让AI准确理解品牌信息',
            '语义关联优化，建立品牌与行业关键词的强关联',
            '多模态内容适配，覆盖文本、图片、视频等多种形式',
            '实时数据监控，72小时内完成策略调整',
          ].map(item => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-purple-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-600">{item}</span>
            </li>
          ))}
        </ul>
        <a href="/about" class="btn-primary">
          了解更多
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right: Feature cards -->
      <div class="grid grid-cols-2 gap-4">
        <div class="card text-center p-6">
          <div class="w-12 h-12 rounded-xl gradient-bg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">AI优化</h3>
          <p class="text-sm text-gray-500">五大AI平台同步优化</p>
        </div>
        <div class="card text-center p-6 mt-8">
          <div class="w-12 h-12 rounded-xl gradient-bg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">精准获客</h3>
          <p class="text-sm text-gray-500">高质量流量转化</p>
        </div>
        <div class="card text-center p-6">
          <div class="w-12 h-12 rounded-xl gradient-bg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">数据分析</h3>
          <p class="text-sm text-gray-500">实时数据看板</p>
        </div>
        <div class="card text-center p-6 mt-8">
          <div class="w-12 h-12 rounded-xl gradient-bg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">快速见效</h3>
          <p class="text-sm text-gray-500">1周部署 3天见效</p>
        </div>
      </div>
    </div>
  </div>
</section>
