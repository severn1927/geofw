<section id="advantages" class="py-20 md:py-28 bg-gray-50">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-purple-50 rounded-full text-purple-600 text-sm font-medium mb-4">
        <span>Our Advantages</span>
      </div>
      <h2 class="section-title">我们的<span class="gradient-text">核心优势</span></h2>
      <p class="section-subtitle">1周内完成优化部署，3天内初步效果显现，确保您的投资快速获得回报</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
      {[
        { number: 500, suffix: '+', label: '合作客户' },
        { number: 30, suffix: '+', label: '涉及行业' },
        { number: 5, suffix: '年', label: '服务经验' },
        { number: 98, suffix: '%', label: '满意度' },
      ].map(stat => (
        <div class="text-center p-6 bg-white rounded-2xl shadow-sm border border-gray-100">
          <div class="text-4xl md:text-5xl font-black gradient-text mb-2">
            <span class="counter" data-target={stat.number}>0</span>{stat.suffix}
          </div>
          <p class="text-gray-500 text-sm font-medium">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Advantage Items -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        {
          title: '快速见效',
          desc: '1周内完成优化部署，3天内初步效果显现，确保您的投资快速获得回报',
          icon: 'M13 10V3L4 14h7v7l9-11h-7z',
        },
        {
          title: '实时数据看板',
          desc: '提供实时数据看板，清晰展示品牌提及率、流量增长等核心指标变化',
          icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
        },
        {
          title: '敏捷策略调整',
          desc: '实时监控AI算法变化，72小时内完成策略调整，保持优化效果稳定',
          icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
        },
        {
          title: '行业定制方案',
          desc: '针对不同行业特点定制优化策略，解决行业特有痛点',
          icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
        },
        {
          title: '五大平台覆盖',
          desc: '让你的企业信息展现在 DeepSeek、Kimi、豆包、腾讯元宝、文心一言等 AI 平台',
          icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
        },
        {
          title: '品牌影响力提升',
          desc: '提升品牌影响力，扩大品牌美誉度，让您的品牌在AI时代保持领先',
          icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
        },
      ].map(adv => (
        <div class="flex gap-4 p-5 bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl gradient-bg flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={adv.icon} />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">{adv.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{adv.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Counter animation
  function animateCounters() {
    const counters = document.querySelectorAll('.counter');
    counters.forEach(counter => {
      const target = parseInt(counter.getAttribute('data-target') || '0');
      const duration = 2000;
      const step = target / (duration / 16);
      let current = 0;
      
      const update = () => {
        current += step;
        if (current < target) {
          counter.textContent = Math.floor(current);
          requestAnimationFrame(update);
        } else {
          counter.textContent = target;
        }
      };
      
      update();
    });
  }

  // Intersection Observer for counter animation
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounters();
        observer.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const statsSection = document.getElementById('advantages');
  if (statsSection) {
    observer.observe(statsSection);
  }
</script>
