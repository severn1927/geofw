---

---

<section id="taocan" class="py-20 md:py-28 bg-white">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-purple-50 rounded-full text-purple-600 text-sm font-medium mb-4">
        <span>AI Package</span>
      </div>
      <h2 class="section-title">专业<span class="gradient-text">优化套餐</span></h2>
      <p class="section-subtitle">专业优化DeepSeek、文心一言、豆包、通义、元宝五大AI平台，提升品牌可见性，获取精准流量</p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <!-- Basic -->
      <div class="card p-8 flex flex-col">
        <div class="mb-6">
          <h3 class="text-xl font-bold text-gray-900 mb-2">基础版</h3>
          <p class="text-sm text-gray-400">适合初创企业体验GEO优化</p>
        </div>
        <div class="mb-6">
          <span class="text-4xl font-black gradient-text">2980</span>
          <span class="text-gray-400 text-sm">元/月</span>
        </div>
        <ul class="space-y-3 mb-8 flex-1">
          {[
            '2个AI平台优化',
            '10个核心关键词',
            '基础品牌信息优化',
            '月度效果报告',
            '工作日客服支持',
          ].map(item => (
            <li class="flex items-center gap-2 text-sm text-gray-600">
              <svg class="w-4 h-4 text-purple-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
        <a href="/contact" class="btn-dark text-center w-full">
          立即咨询
        </a>
      </div>

      <!-- Pro (Recommended) -->
      <div class="relative card p-8 flex flex-col border-2 border-purple-500 shadow-xl scale-105">
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 px-4 py-1 gradient-bg text-white text-xs font-bold rounded-full">
          推荐
        </div>
        <div class="mb-6">
          <h3 class="text-xl font-bold text-gray-900 mb-2">专业版</h3>
          <p class="text-sm text-gray-400">适合成长型企业深度优化</p>
        </div>
        <div class="mb-6">
          <span class="text-4xl font-black gradient-text">6980</span>
          <span class="text-gray-400 text-sm">元/月</span>
        </div>
        <ul class="space-y-3 mb-8 flex-1">
          {[
            '5大AI平台全覆盖',
            '30个核心关键词',
            '深度品牌信息优化',
            '多平台内容部署',
            '周度效果报告',
            '7x12小时客服支持',
            '专属客户经理',
          ].map(item => (
            <li class="flex items-center gap-2 text-sm text-gray-600">
              <svg class="w-4 h-4 text-purple-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
        <a href="/contact" class="btn-primary text-center w-full">
          立即咨询
        </a>
      </div>

      <!-- Enterprise -->
      <div class="card p-8 flex flex-col">
        <div class="mb-6">
          <h3 class="text-xl font-bold text-gray-900 mb-2">企业版</h3>
          <p class="text-sm text-gray-400">适合大型企业定制化方案</p>
        </div>
        <div class="mb-6">
          <span class="text-4xl font-black gradient-text">定制</span>
          <span class="text-gray-400 text-sm">报价</span>
        </div>
        <ul class="space-y-3 mb-8 flex-1">
          {[
            '全部AI平台优化',
            '不限关键词数量',
            '全方位品牌优化',
            '全网多平台部署',
            '实时数据看板',
            '7x24小时专属服务',
            '定制化策略方案',
            '季度竞品分析报告',
          ].map(item => (
            <li class="flex items-center gap-2 text-sm text-gray-600">
              <svg class="w-4 h-4 text-purple-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
        <a href="/contact" class="btn-dark text-center w-full">
          联系我们
        </a>
      </div>
    </div>
  </div>
</section>
