---
const currentYear = new Date().getFullYear();
const services = [
  { label: 'AI平台优化', href: '/services' },
  { label: '规划热搜词条', href: '/services' },
  { label: '多平台布局', href: '/services' },
  { label: '官网搭建/SEO优化', href: '/services' },
];
const quickLinks = [
  { label: '关于我们', href: '/#about' },
  { label: '服务项目', href: '/services' },
  { label: '新闻动态', href: '/blog' },
  { label: '联系我们', href: '/contact' },
];
---

<footer class="bg-dark-purple text-text-footer">
  <!-- Main Footer -->
  <div class="container-custom py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <img src="/logo.png" alt="友擎GEO Logo" class="w-10 h-10" width="40" height="40" />
          <span class="text-xl font-bold text-white">友擎GEO</span>
        </a>
        <p class="text-gray-300 text-sm leading-relaxed mb-6">
          专注于AI平台GEO优化，帮助企业提升在DeepSeek、文心一言、豆包、通义、元宝等平台的可见性与影响力。
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-base">我们的服务</h3>
        <ul class="space-y-3">
          {services.map(service => (
            <li>
              <a href={service.href} class="text-gray-300 text-sm hover:text-purple-400 transition-colors">
                {service.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-base">快速导航</h3>
        <ul class="space-y-3">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-gray-300 text-sm hover:text-purple-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-base">联系我们</h3>
        <ul class="space-y-3 text-sm text-gray-300">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-purple-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:400-888-8888" class="hover:text-purple-400 transition-colors">400-888-8888</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-purple-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:contact@geofw.cn" class="hover:text-purple-400 transition-colors">contact@geofw.cn</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-purple-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>中国</span>
          </li>
        </ul>
        <!-- Social Icons placeholder -->
        <div class="flex gap-3 mt-5">
          <a href="#" class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center text-gray-300 hover:bg-purple-600 hover:text-white transition-all" aria-label="微信">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm3.2 4.127c-3.866 0-7.007 2.58-7.007 5.765 0 3.184 3.141 5.764 7.006 5.764.757 0 1.49-.1 2.176-.29a.667.667 0 01.557.076l1.478.865a.262.262 0 00.13.043.228.228 0 00.226-.23c0-.056-.023-.11-.038-.165l-.303-1.15a.464.464 0 01.165-.516C21.407 19.795 22.4 18.172 22.4 16.083c0-3.185-3.14-5.765-7.002-5.765zm-2.423 3.234c.499 0 .903.41.903.915a.909.909 0 01-.903.916.909.909 0 01-.903-.916c0-.505.404-.915.903-.915zm4.846 0c.499 0 .903.41.903.915a.909.909 0 01-.903.916.909.909 0 01-.903-.916c0-.505.404-.915.903-.915z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center text-gray-300 hover:bg-purple-600 hover:text-white transition-all" aria-label="微博">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.194 14.197c0 3.248-3.865 5.88-8.636 5.88-4.77 0-8.635-2.632-8.635-5.88s3.865-5.88 8.635-5.88c4.77 0 8.636 2.632 8.636 5.88z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="container-custom py-5 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-sm text-gray-400">
        &copy; {currentYear} 友擎GEO. All rights reserved.
      </p>
      <div class="flex items-center gap-4 text-sm text-gray-400">
        <a href="/sitemap-index.xml" class="hover:text-purple-400 transition-colors">网站地图</a>
        <span>|</span>
        <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer" class="hover:text-purple-400 transition-colors">
          京ICP备XXXXXXXX号
        </a>
      </div>
    </div>
  </div>
</footer>
