---

<section id="fuwu" class="py-20 md:py-28 bg-white">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-purple-50 rounded-full text-purple-600 text-sm font-medium mb-4">
        <span>Our Services</span>
      </div>
      <h2 class="section-title">我们的<span class="gradient-text">服务项目</span></h2>
      <p class="section-subtitle">针对不同需求提供灵活高效的优化方案，确保您的品牌在AI搜索结果中获得最佳曝光</p>
    </div>

    <!-- Service Cards Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, index) => (
        <div class="card group hover:shadow-xl cursor-pointer">
          <div class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconMap[service.icon]} />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-purple-600 transition-colors">{service.title}</h3>
          <p class="text-gray-500 leading-relaxed text-sm">{service.description}</p>
          <div class="mt-5 flex items-center gap-1 text-purple-600 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
            了解详情
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
